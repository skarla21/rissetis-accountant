# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# Public contact email shown on the site.
NEXT_PUBLIC_RISSETIS_EMAIL=

# Google reCAPTCHA v3 site key (public) used by the contact form.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Google Maps API key for the embedded map.
NEXT_PUBLIC_MAPS_API_KEY=

# Password gating the /admin article manager (checked server-side in the add/remove actions).
ADMIN_PASSWORD=

# Fine-grained GitHub PAT scoped to skarla21/rissetis-accountant with Contents: Read and write.
# The admin page uses it to commit article-list changes to src/data/articles.json.
GITHUB_TOKEN=

# Vercel Deploy Hook URL (Project > Settings > Git > Deploy Hooks, branch: main).
# After an admin commit, the app POSTs here to rebuild the public site.
VERCEL_DEPLOY_HOOK_URL=
